# Paths AI agents/tools should skip to save tokens.
# Mirrors .gitignore plus committed-but-generated artifacts and token-heavy noise.
# See docs/ai/REPO_MAP.md for what IS worth reading.

# Dependencies / vendor
node_modules/

# Build output / caches
dist/
coverage/
*.tsbuildinfo
.vite/
.turbo/

# Generated artifacts (regenerate with the noted command; do not hand-edit)
schema/generated/         # pnpm schema:export
content/canon-index.json  # pnpm pipeline:export

# Test / report output
test-results/
playwright-report/
playwright/.cache/

# Lockfile + logs (large, low-signal)
pnpm-lock.yaml
*.log

# OS
.DS_Store
