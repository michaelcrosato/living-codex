# Environment variables for The Living Codex.
# Read directly from the shell environment (no .env auto-loading) — export these
# before running the offline content pipeline. Copy to your own .env if you wire one up.

# Offline content pipeline (tools/pipeline) — ONLY needed to run REAL generation via
# `pnpm pipeline:cycle` / `pnpm pipeline:bake`. Without it a deterministic demo stub runs,
# so the engine, the test suite, and `pnpm verify` need nothing here.
OPENROUTER_API_KEY=

# Optional: model id for the OpenRouter provider (default shown).
PIPELINE_MODEL=anthropic/claude-opus-4.6
