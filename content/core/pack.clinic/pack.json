  "npcs": [
    {
      "id": "npc.clinic_medic",
      "name": "Sister Vane",
      "appearance": {
        "bodyColor": "#c7d2cc",
        "accentColor": "#5ad0c0",
        "silhouette": "humanoid"
      },
      "bio": {
        "role": "back-alley medic",
        "backstory": "Trained somewhere that issued real licenses, once. Now she stitches dockhands and fixers in a room that smells of bleach, asks no questions, and keeps a ledger of who still owes her. Nobody's medic but her own.",
        "wants": "to be paid what she's owed, and to keep the lights on for the people no clinic uptown will touch",
        "fears": "owing anyone — the one debt she can't write off",
        "voice": "dry, unhurried, kind in a way that costs her something",
        "secrets": [
          "She treats Varga's crew and the Syndicate both, and tells neither."
        ]
      },
      "dialogueId": "dialogue.clinic_medic",
      "homeLocationId": "location.ashfall_clinic",
      "reactsTo": [
        {
          "when": [
            {
              "kind": "flag_is",
              "flag": "flag.syndicate_made_member",
              "equals": true
            }
          ],
          "setsFlags": [],
          "overrideDialogueId": "dialogue.medic_syndicate"
        },
        {
          "when": [
            {
              "kind": "flag_is",
              "flag": "flag.varga_inner_circle",
              "equals": true
            }
          ],
          "setsFlags": [],
          "overrideDialogueId": "dialogue.medic_varga"
        }
      ]
    }
  ],
  "dialogues": [
    {
      "id": "dialogue.clinic_medic",
      "format": "ink-json",
      "inkVersion": "21",
      "sourceHash": "0c4c53cba88a16",
      "compiled": {
        "inkVersion": 21,
        "root": [
          [
            "ev",
            true,
            "/ev",
            {
              "VAR=": "met_medic",
              "re": true
            },
            "^The medic doesn't look up from the tray she's sterilizing. \"Sit if you're bleeding. Talk if you're not.\" She finally meets your eyes — tired, sharp, unafraid. \"You look like someone who collects debts. I've got one that won't collect itself. A supplier took my coin and left me dry. Interested, or just browsing?\"",
            "\n",
            "ev",
            "str",
            "^Tell me about the debt.",
            "/str",
            "/ev",
            {
              "*": "0.c-0",
              "flg": 20
            },
            "ev",
            "str",
            "^I patch up, I don't collect.",
            "/str",
            "/ev",
            {
              "*": "0.c-1",
              "flg": 20
            },
            "ev",
            "str",
            "^Not my problem.",
            "/str",
            "/ev",
            {
              "*": "0.c-2",
              "flg": 20
            },
            {
              "c-0": [
                "\n",
                "^\"Mendez. Runs cut supply out of the undermarket. Took payment for a shipment that never came. I want what I paid for, or the coin back. Don't much care which.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "c-1": [
                "\n",
                "^\"Pity. The patching's free if you ever do change your mind. Door's open.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "c-2": [
                "\n",
                "^\"No. Most things aren't, until they are.\" She turns back to the tray.",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "g-0": [
                "done",
                null
              ]
            }
          ],
          "done",
          {
            "global decl": [
              "ev",
              false,
              {
                "VAR=": "met_medic"
              },
              "/ev",
              "end",
              null
            ]
          }
        ],
        "listDefs": {}
      },
      "declaredVars": [
        "met_medic"
      ]
    },
    {
      "id": "dialogue.medic_syndicate",
      "format": "ink-json",
      "inkVersion": "21",
      "sourceHash": "164cdf8c372081",
      "compiled": {
        "inkVersion": 21,
        "root": [
          [
            "^She clocks the way you carry yourself now. \"Syndicate. I wondered.\" She doesn't stop working. \"I stitch their people same as anyone's — same as Varga's. I don't ask whose coin it is, and I don't tell. You're not special, and that's the safest thing I can offer you. Try not to bleed where it shows.\"",
            "\n",
            "ev",
            "str",
            "^Understood.",
            "/str",
            "/ev",
            {
              "*": "0.c-0",
              "flg": 20
            },
            {
              "c-0": [
                "\n",
                "^\"Good. Understanding's cheap. Keeping it is the trick.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "g-0": [
                "done",
                null
              ]
            }
          ],
          "done",
          null
        ],
        "listDefs": {}
      },
      "declaredVars": []
    },
    {
      "id": "dialogue.medic_varga",
      "format": "ink-json",
      "inkVersion": "21",
      "sourceHash": "0383f06822ad7a",
      "compiled": {
        "inkVersion": 21,
        "root": [
          [
            "^\"Varga's inner circle.\" She says it flat, no judgment. \"I've stitched half of them, one time or another. Loyalty's a wound that doesn't close, in this city — but it's a clean way to bleed, if you're going to.\" She nods at the door. \"Tell her Vane says her people heal slow when they're carrying something.\"",
            "\n",
            "ev",
            "str",
            "^I'll tell her.",
            "/str",
            "/ev",
            {
              "*": "0.c-0",
              "flg": 20
            },
            {
              "c-0": [
                "\n",
                "^\"Don't, actually. She'll know what I mean, and she won't thank you for the message.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "g-0": [
                "done",
                null
              ]
            }
          ],
          "done",
          null
        ],
        "listDefs": {}
      },
      "declaredVars": []
    }
  ],
  "quests": [
    {
      "id": "quest.clinic_debt",
      "title": "Bad Blood",
      "giverNpcId": "npc.clinic_medic",
      "summary": "The clinic's supplier, Mendez, took payment for a shipment that never came. Sister Vane wants her coin or her supplies back. Lean on him, talk him down, or decide it isn't your fight.",
      "offerWhen": [
        {
          "kind": "flag_is",
          "flag": "flag.met_medic",
          "equals": true
        }
      ],
      "branches": [
        {
          "id": "lean_on",
          "label": "Lean on Mendez",
          "objectives": [
            {
              "kind": "talk_to",
              "npcId": "npc.clinic_medic"
            },
            {
              "kind": "reach",
              "locationId": "location.drip_market"
            },
            {
              "kind": "skill_check",
              "skill": "force",
              "dc": 12,
              "onFail": [
                {
                  "kind": "show_text",
                  "text": "Mendez has muscle of his own, and today they're paying attention. You leave with less than you came for."
                }
              ]
            }
          ],
          "onComplete": [
            {
              "kind": "set_flag",
              "flag": "flag.clinic_debt_forced",
              "to": true
            }
          ]
        },
        {
          "id": "talk_down",
          "label": "Talk Mendez into paying",
          "objectives": [
            {
              "kind": "talk_to",
              "npcId": "npc.clinic_medic"
            },
            {
              "kind": "reach",
              "locationId": "location.drip_market"
            },
            {
              "kind": "skill_check",
              "skill": "persuade",
              "dc": 12,
              "onFail": [
                {
                  "kind": "show_text",
                  "text": "Mendez smiles, agrees to everything, and means none of it. You'll be back."
                }
              ]
            }
          ],
          "onComplete": [
            {
              "kind": "set_flag",
              "flag": "flag.clinic_debt_settled",
              "to": true
            }
          ]
        }
      ],
      "onAnyComplete": [
        {
          "kind": "set_flag",
          "flag": "flag.clinic_debt_resolved",
          "to": true
        }
      ],
      "rewards": {
        "credits": 90,
        "items": [],
        "reputation": []
      }
    }
