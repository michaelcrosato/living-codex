  "dialogues": [
    {
      "id": "dialogue.drip_vendor",
      "format": "ink-json",
      "inkVersion": "21",
      "sourceHash": "1abb10d17a3814",
      "compiled": {
        "inkVersion": 21,
        "root": [
          [
            "^Marrow wipes a glass that will never be clean. \"Ashfall sent collectors. I'm short. You look like someone who settles things.\"",
            "\n",
            "ev",
            "str",
            "^Hear her out",
            "/str",
            "/ev",
            {
              "*": "0.c-0",
              "flg": 20
            },
            "ev",
            "str",
            "^Name a price",
            "/str",
            "/ev",
            {
              "*": "0.c-1",
              "flg": 20
            },
            "ev",
            "str",
            "^Walk the stalls first",
            "/str",
            "/ev",
            {
              "*": "0.c-2",
              "flg": 20
            },
            {
              "c-0": [
                "\n",
                "^\"Three ways this goes. Talk them down, scare them off, or slip the ledger. Your call.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "c-1": [
                "\n",
                "^\"Everyone does. Fix this and I remember faces.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "c-2": [
                "\n",
                "^\"Don't take too long. They don't.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "g-0": [
                "done",
                null
              ]
            }
          ],
          "done",
          null
        ],
        "listDefs": {}
      },
      "declaredVars": []
    },
    {
      "id": "dialogue.drip_enforcer",
      "format": "ink-json",
      "inkVersion": "21",
      "sourceHash": "1795e39c65d9ac",
      "compiled": {
        "inkVersion": 21,
        "root": [
          [
            "^The collector cracks his knuckles. \"Marrow's debt is Marrow's problem. Unless you're making it yours.\"",
            "\n",
            "ev",
            "str",
            "^Stare him down",
            "/str",
            "/ev",
            {
              "*": "0.c-0",
              "flg": 20
            },
            "ev",
            "str",
            "^Offer to pay",
            "/str",
            "/ev",
            {
              "*": "0.c-1",
              "flg": 20
            },
            "ev",
            "str",
            "^Say nothing",
            "/str",
            "/ev",
            {
              "*": "0.c-2",
              "flg": 20
            },
            {
              "c-0": [
                "\n",
                "^\"Big talk. Back it up or back off.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "c-1": [
                "\n",
                "^\"Credits talk louder than you do. Maybe.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "c-2": [
                "\n",
                "^\"Smart. Walk.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "g-0": [
                "done",
                null
              ]
            }
          ],
          "done",
          null
        ],
        "listDefs": {}
      },
      "declaredVars": []
    },
    {
      "id": "dialogue.drip_informant",
      "format": "ink-json",
      "inkVersion": "21",
      "sourceHash": "0d7f06ca6331da",
      "compiled": {
        "inkVersion": 21,
        "root": [
          [
            "^A thin figure in the doorway whispers. \"You want the ledger? It's in the back. They keep it behind the broken wall — you'd need to be strong, or quiet.\"",
            "\n",
            "ev",
            "str",
            "^Ask about the wall",
            "/str",
            "/ev",
            {
              "*": "0.c-0",
              "flg": 20
            },
            "ev",
            "str",
            "^Ask about staying quiet",
            "/str",
            "/ev",
            {
              "*": "0.c-1",
              "flg": 20
            },
            "ev",
            "str",
            "^Leave the doorway",
            "/str",
            "/ev",
            {
              "*": "0.c-2",
              "flg": 20
            },
            {
              "c-0": [
                "\n",
                "^\"Collapsed years ago. Some still shove through it. Mind the rebar.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "c-1": [
                "\n",
                "^\"Slip past at the right moment. If you're the type.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "c-2": [
                "\n",
                "^\"Suit yourself. I was never here.\"",
                "\n",
                "end",
                {
                  "->": "0.g-0"
                },
                {
                  "#f": 5
                }
              ],
              "g-0": [
                "done",
                null
              ]
            }
          ],
          "done",
          null
        ],
        "listDefs": {}
      },
      "declaredVars": []
    }
