            }
          ],
          "setsFlags": [
            {
              "kind": "set_flag",
              "flag": "flag.marrow_grateful",
              "to": true
            }
          ]
        }
      ]
    },
    {
      "id": "npc.drip_enforcer",
      "name": "Coll",
      "faction": "faction.ashfall_syndicate",
      "appearance": {
        "bodyColor": "#23282d",
        "accentColor": "#c84b4b",
        "silhouette": "tall"
      },
      "bio": {
        "role": "Syndicate collector",
        "backstory": "Promoted for being the one who didn't flinch.",
        "wants": "Marrow's debt, with interest",
        "fears": "looking soft in front of the crew",
        "voice": "flat, unhurried, certain",
        "secrets": []
      },
      "dialogueId": "dialogue.drip_enforcer",
      "combat": {
        "hp": 8
      },
      "homeLocationId": "location.drip_market",
      "reactsTo": []
    },
    {
      "id": "npc.drip_informant",
      "name": "Wren",
      "appearance": {
        "bodyColor": "#1f2630",
        "accentColor": "#6fb3c0",
        "silhouette": "cloaked"
      },
      "bio": {
        "role": "doorway informant",
        "backstory": "Sees everything from the edges; sells most of it.",
        "wants": "to stay invisible and solvent",
        "fears": "being remembered",
        "voice": "a whisper that assumes you're listening",
        "secrets": [
          "Knows where the ledger is."
        ]
      },
      "dialogueId": "dialogue.drip_informant",
      "homeLocationId": "location.drip_market",
      "reactsTo": []
    }
  ],
  "quests": [
    {
      "id": "quest.market_debt",
      "title": "The Drip Market Debt",
      "giverNpcId": "npc.drip_vendor",
      "summary": "Marrow owes the Syndicate. Talk the collector down, muscle the ledger out of the back room, or have Wren make the debt quietly disappear.",
      "offerWhen": [
        {
          "kind": "flag_is",
          "flag": "flag.met_marrow",
          "equals": true
        }
      ],
      "branches": [
        {
          "id": "settle_talk",
          "label": "Talk the collector down",
          "objectives": [
            {
              "kind": "talk_to",
              "npcId": "npc.drip_enforcer"
            }
          ],
          "onComplete": [
            {
              "kind": "adjust_reputation",
              "factionId": "faction.ashfall_syndicate",
              "delta": 10
            }
          ]
        },
        {
          "id": "settle_muscle",
          "label": "Take the ledger by force",
          "objectives": [
            {
              "kind": "skill_check",
              "skill": "force",
              "dc": 10
            }
          ],
          "onComplete": [
            {
              "kind": "set_flag",
              "flag": "flag.market_muscled",
              "to": true
            }
          ]
        },
        {
          "id": "settle_sneak",
          "label": "Let Wren make it disappear",
          "objectives": [
            {
              "kind": "talk_to",
              "npcId": "npc.drip_informant"
            }
          ],
          "onComplete": [
            {
              "kind": "set_flag",
              "flag": "flag.market_sneaked",
              "to": true
            }
          ]
        }
      ],
      "onAnyComplete": [
        {
          "kind": "set_flag",
          "flag": "flag.market_debt_resolved",
          "to": true
        }
      ],
      "rewards": {
        "credits": 100,
        "items": [],
        "reputation": []
      }
    }
