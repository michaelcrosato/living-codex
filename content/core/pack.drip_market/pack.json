  "npcs": [
    {
      "id": "npc.drip_vendor",
      "name": "Marrow",
      "appearance": {
        "bodyColor": "#3a2f2a",
        "accentColor": "#d8a657",
        "silhouette": "stocky"
      },
      "bio": {
        "role": "market vendor in debt",
        "backstory": "Ran a clean stall for a decade until the Syndicate 'invested'.",
        "wants": "to clear her debt without losing the stall",
        "fears": "the collectors making an example of her",
        "voice": "dry, tired, quick with a deal",
        "secrets": [
          "She has been skimming to pay a different debt."
        ]
      },
      "dialogueId": "dialogue.drip_vendor",
      "homeLocationId": "location.drip_market",
      "reactsTo": [
        {
          "when": [
