{
  "name": "living-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @codex/app-web dev",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.dom.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "deps:check": "depcruise packages tools --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "schema:export": "tsx tools/scripts/schema-export.ts",
    "content:new": "tsx tools/scripts/content-new.ts",
    "content:compile-ink": "tsx tools/scripts/compile-ink.ts",
    "pipeline:export": "tsx tools/scripts/pipeline-export.ts",
    "pipeline:cycle": "tsx tools/scripts/pipeline-cycle.ts",
    "pipeline:bake": "tsx tools/scripts/pipeline-bake-patrons.ts",
    "content:validate": "tsx tools/scripts/content-validate.ts",
    "content:verify": "tsx tools/scripts/content-verify.ts",
    "replay:verify": "vitest run -t \"replay invariant\"",
    "e2e": "playwright test -c packages/app-web/playwright.config.ts",
    "verify": "pnpm typecheck && pnpm lint && pnpm deps:check && pnpm test && pnpm content:validate && pnpm content:verify && pnpm replay:verify",
    "agent:bootstrap": "bash scripts/agent/bootstrap.sh",
    "agent:doctor": "bash scripts/agent/doctor.sh",
    "agent:test": "bash scripts/agent/test.sh",
    "agent:lint": "bash scripts/agent/lint.sh",
    "agent:typecheck": "bash scripts/agent/typecheck.sh",
    "agent:format": "bash scripts/agent/format.sh",
    "agent:check": "bash scripts/agent/check.sh",
    "agent:status": "bash scripts/agent/status.sh",
    "agent:preflight": "bash scripts/agent/afk-preflight.sh",
    "agent:afk-status": "bash scripts/agent/afk-status.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "3.2.4",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^9.18.0",
    "fake-indexeddb": "^6.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.2"
  },
  "dependencies": {
    "fast-check": "^3.23.2",
    "miniplex": "^2.0.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  }
}
