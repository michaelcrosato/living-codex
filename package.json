{
  "name": "living-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @codex/app-web dev",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "deps:check": "depcruise packages tools --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "schema:export": "tsx tools/scripts/schema-export.ts",
    "content:validate": "tsx tools/scripts/content-validate.ts",
    "content:verify": "tsx tools/scripts/content-verify.ts",
    "replay:verify": "vitest run -t \"replay invariant\"",
    "verify": "pnpm typecheck && pnpm lint && pnpm deps:check && pnpm test && pnpm content:validate && pnpm content:verify && pnpm replay:verify"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "dependency-cruiser": "^16.9.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.2"
  },
  "dependencies": {
    "fast-check": "^3.23.2",
    "miniplex": "^2.0.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  }
}
