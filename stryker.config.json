{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "SPEC-30: mutation testing scoped to the pure determinism-critical engine-core. Report-only — establishes a baseline mutation score; not wired into the blocking `pnpm verify` gate.",
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner", "@stryker-mutator/typescript-checker"],
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": ["packages/engine-core/src/**/*.ts", "!packages/engine-core/src/**/*.test.ts"],
  "reporters": ["clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "incremental": true,
  "concurrency": 4,
  "timeoutMS": 20000
}
